{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gothailandhome.com/schemas/developer.manifest.json",
  "type": "object",
  "required": [
    "slug",
    "collected_at",
    "publish_ready",
    "sources",
    "name",
    "seo"
  ],
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "collected_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "publish_ready": { "type": "boolean" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "source.json" }
    },
    "name": { "$ref": "i18n-string.json" },
    "legal_name": { "$ref": "i18n-string.json" },
    "description": { "$ref": "i18n-string.json" },
    "website": { "type": ["string", "null"], "format": "uri" },
    "facebook_url": { "type": ["string", "null"], "format": "uri" },
    "google_maps_url": { "type": ["string", "null"], "format": "uri" },
    "logo_url": { "type": ["string", "null"] },
    "phone": { "type": ["string", "null"] },
    "email": { "type": ["string", "null"] },
    "seo": {
      "type": "object",
      "required": ["title", "description"],
      "properties": {
        "title": { "$ref": "i18n-string.json" },
        "description": { "$ref": "i18n-string.json" }
      },
      "additionalProperties": false
    },
    "locale_status": {
      "type": "object",
      "properties": {
        "en": { "type": "string" },
        "zh": { "type": "string" },
        "th": { "type": "string" }
      }
    },
    "project_slugs": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
